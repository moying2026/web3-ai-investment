# Web3 AI 投资决策系统 — 环境变量配置
# ⚠️ 此文件包含敏感信息，禁止提交到 git

# 注册邮箱
REGISTER_EMAIL=wwtopenclaw@agentmail.to

# 代理配置
HTTPS_PROXY=http://127.0.0.1:7897
HTTP_PROXY=http://127.0.0.1:7897

# Etherscan API V2 Key（统一 key，覆盖 BSC + 60+ EVM 链）
# https://api.etherscan.io/v2/api
ETHERSCAN_V2_KEY=
ETHERSCAN_V2_BASE_URL=https://api.etherscan.io/v2/api

# BscScan API Key (BSC 链) - https://bscscan.com
API_KEY_BSCSCAN=

# Etherscan API Key (ETH 主网) - https://etherscan.io
API_KEY_ETHERSCAN=

# BaseScan API Key (Base 链) - https://basescan.org
API_KEY_BASESCAN=

# Solscan API Key (Solana 链) - https://solscan.io
API_KEY_SOLSCAN=

# CoinGecko API Key (可选，免费 tier 无需 key)
API_KEY_COINGECKO=

# Binance Web3 API 基础 URL（可选，默认直连）
BINANCE_BASE_URL=https://www.binance.com
